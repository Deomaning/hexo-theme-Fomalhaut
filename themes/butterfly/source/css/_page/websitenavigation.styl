// 网址导航
.goodwebnavigation-title
  margin: 1rem 0
  line-height: 1;

.webnavigation-item
  .webnavigation-item-content
    display: flex
    flex-direction: row
    flex-wrap: wrap
    margin: 0 -8px

    .webnavigation-item-content-item
      width: calc(25% - 12px)
      border-radius: 12px
      border: var(--style-border-always)
      overflow: hidden
      margin: 8px 6px
      background: var(--anzhiyu-card-bg)
      box-shadow: var(--anzhiyu-shadow-border)
      min-height: 400px
      position: relative
      +maxWidth1200()
        width: calc(50% - 12px)
      +maxWidth768()
        width: 100%

      &:hover
        border: 2px solid #cdd1d3;
        box-shadow: 0 5px 10px 8px #07111b29;
        transform: translateY(-3px);

      .webnavigation-item-content-item-info
        padding: 8px 16px 16px 16px
        margin-top: 12px

      .webnavigation-item-content-item-name
        font-size: 18px
        font-weight: bold
        line-height: 1
        margin-bottom: 8px
        white-space: nowrap
        overflow: visable
        text-overflow: ellipsis
        width: fit-content
        cursor pointer

        &:hover
          color: var(--anzhiyu-main)

      .webnavigation-item-content-item-specification
        font-size: 12px
        color: var(--anzhiyu-secondtext)
        line-height: 16px
        margin-bottom: 5px
        white-space: nowrap
        overflow: hidden
        text-overflow: ellipsis

      .webnavigation-item-content-item-description
        line-height: 20px
        color: var(--anzhiyu-secondtext)
        height: 60px
        display: -webkit-box
        overflow: hidden
        -webkit-line-clamp: 3
        -webkit-box-orient: vertical
        font-size: 14px

      a.webnavigation-item-content-item-link
        font-size: 15px
        background: var(--anzhiyu-gray-op)
        padding: 4px 8px
        border-radius: 8px
        cursor: pointer

        &:hover
          background: var(--anzhiyu-main)
          color: var(--anzhiyu-white)

      .webnavigation-item-content-item-cover
        width: 100%
        height: 200px
        background: var(--anzhiyu-secondbg)
        display: flex
        justify-content: center
        align-items: center;

      img.webnavigation-item-content-item-image
        object-fit: cover
        height: 100%
        width: 100%
        transition all 1s

      // border-radius: 0
      // 若需要去除图片圆角可以将这里的注释去掉
      // &:hover
      //   transform scale(1.3)

      .webnavigation-item-content-item-toolbar
        display: flex
        justify-content: space-between
        position: absolute
        bottom: 12px
        left: 0
        width: 100%
        padding: 0 16px

//.webnavigation-item-content-item:hover
body[data-type="websitenavigation"] #web_bg
  background: var(--anzhiyu-background);
  max-width: 1400px !important;

body[data-type="websitenavigation"] #page
  max-width: 1400px !important;
  border: 0;
  box-shadow: none !important;
  padding: 0 !important;
  background: 0 0 !important;

body[data-type="websitenavigation"] #page .page-title
  display: none;

//  前几个貌似没有生效,不太理解这种写法
#web_bg ~ .page:has(#websitenavigation) {
  #content-inner {
    max-width: 1400px !important;
  }
}
