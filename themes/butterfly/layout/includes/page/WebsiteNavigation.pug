#websitenavigation
    if site.data.websitenavigation
        each i in site.data.websitenavigation
            .author-content.author-content-item.webnavigationPage.single
                .card-content
                    .author-content-item-tips=i.class_name
                    span.author-content-item-title=i.description
                    .content-bottom
                        .tips=i.tip
                    //.banner-button-group
                    //    a.banner-button(href=i.buttonLink)
                    //        i.fas.fa-circle-right(style='font-size: 1.5rem')
                    //        span.banner-button-text=i.buttonText
                    //        span.shimmer
            each item in i.good_navlists
                .goodwebnavigation-item
                    h2.goodwebnavigation-title= item.title
                    .goodwebnavigation-item-description= item.description
                    .webnavigation-item
                        .webnavigation-item-content
                            each iten, indey in item.webnavigation_list
                                .webnavigation-item-content-item
                                    .webnavigation-item-content-item-cover
                                        img.webnavigation-item-content-item-image(data-lazy-src=url_for(iten.image) onerror=`this.onerror=null;this.src='` + url_for(theme.error_img.flink) + `'` alt=iten.name)
                                    .webnavigation-item-content-item-info
                                        .webnavigation-item-content-item-name(onclick=`rm.rightmenuCopyText("${iten.name}");anzhiyu.snackbarShow("${_p('Snackbar.copy_webnavigation_name') + " 【" + iten.name + "】"}");` title=iten.name)= iten.name
                                        .webnavigation-item-content-item-specification= iten.specification
                                        .webnavigation-item-content-item-description= iten.description
                                        .webnavigation-item-content-item-toolbar
                                            if iten.link.includes('https://') || iten.link.includes('http://')
                                                a.webnavigation-item-content-item-link(href= iten.link, target='_blank') 详情
                                                .bber-reply(onclick="rm.rightMenuCommentText(" + `'${iten.name + " " + iten.specification + " " + iten.description}'` + ")")
                                                    i.anzhiyufont.anzhiyu-icon-message
                                            else
                                                a.webnavigation-item-content-item-link(href= iten.link, target='_blank') 评论
                                                .bber-reply(onclick="rm.rightMenuCommentText(" + `'${iten.name + " " + iten.specification + " " + iten.description}'` + ")")
                                                    i.anzhiyufont.anzhiyu-icon-message
